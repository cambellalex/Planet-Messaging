# Database
# Prisma Accelerate URL (used by the app at runtime)
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=<your-accelerate-api-key>"
# Direct Postgres URL (used by prisma migrate — get this from the Prisma Platform dashboard)
DIRECT_URL="postgresql://user:pass@host:5432/dbname"

# Session signing (generate with: openssl rand -base64 32)
SESSION_SECRET=""

# Twilio (SMS / WhatsApp)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TWILIO_WEBHOOK_URL=""

# Email channel
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""

# Node environment (set to "production" on Vercel automatically)
NODE_ENV="production"
