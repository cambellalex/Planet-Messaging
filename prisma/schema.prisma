generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id            String   @id @default(cuid())
  name          String
  plan          String   @default("free")
  pricingConfig Json?
  createdAt     DateTime @default(now())

  users     User[]
  messages  Message[]
  channels  Channel[]
  contacts  Contact[]
  campaigns Campaign[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  firstName      String
  lastName       String
  passwordHash   String
  role           String   @default("member")
  organisationId String
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
}

model Contact {
  id             String   @id @default(cuid())
  name           String
  phone          String?
  email          String?
  tags           String[]
  groupName      String?
  extraFields    Json?
  organisationId String
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
}

model Message {
  id             String    @id @default(cuid())
  direction      String
  channel        String
  from           String
  to             String
  body           String
  status         String    @default("queued")
  twilioSid      String?
  organisationId String
  campaignId     String?
  createdAt      DateTime  @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
  campaign     Campaign?    @relation(fields: [campaignId], references: [id])
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  channel        String
  body           String
  status         String   @default("complete")
  totalCount     Int      @default(0)
  sentCount      Int      @default(0)
  failedCount    Int      @default(0)
  organisationId String
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
  messages     Message[]
}

model Channel {
  id             String   @id @default(cuid())
  type           String
  status         String   @default("disconnected")
  credentials    Json
  organisationId String
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
}
